# Database Configuration
# For PostgreSQL (recommended):
DATABASE_URL=postgresql://username:password@localhost:5432/agora_ai

# For SQLite (development only):
# DATABASE_URL=sqlite:///./agora_ai.db

# Redis Configuration
# Local Redis:
# REDIS_URL=redis://localhost:6379/0
# Upstash Redis (TLS):
REDIS_URL=rediss://default:your_password@your-redis.upstash.io:6379

# API Keys
GROQ_API_KEY=your_groq_api_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Optional: OpenAI API Key (if using OpenAI instead of Groq)
# OPENAI_API_KEY=your_openai_api_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here